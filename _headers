# Cache headers voor GitHub Pages (Fastly CDN)
# Lange cache voor statische assets, korte cache voor HTML

/images/*.webp
  Cache-Control: public, max-age=31536000, immutable

/images/*.png
  Cache-Control: public, max-age=31536000, immutable

/images/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/images/*.ico
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=86400

/content.json
  Cache-Control: public, max-age=86400

/index.html
  Cache-Control: public, max-age=600

/
  Cache-Control: public, max-age=600
